{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/skills/forgeproof/scripts/forgeproof.py gate-pr 2>/dev/null || python ${CLAUDE_PLUGIN_ROOT}/skills/forgeproof/scripts/forgeproof.py gate-pr",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if ls .forgeproof/chain-*.json 1>/dev/null 2>&1; then python ${CLAUDE_PLUGIN_ROOT}/skills/forgeproof/scripts/forgeproof.py lint --quiet 2>&1 | head -20; fi; true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
